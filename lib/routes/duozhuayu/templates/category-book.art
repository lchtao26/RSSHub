<img src="{{ item.imgUrl }}"><br>
书名：{{ item.title }}<br>
作者：{{ item.author }}<br>
出版社：{{ item.publisher }}<br>
出版时间：{{ item.publishDate }}<br>
价格：{{ item.price }}<br>
{{ if item.comment }}<p>评论：{{ item.comment }}</p>{{ /if }}
{{ if item.user }}<p>评论者：{{ item.user }}</p>{{ /if }}
{{ if item.dateText }}<p>评论时间：{{ item.dateText }}</p>{{ /if }}
